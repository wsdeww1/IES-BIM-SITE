# ─────────────────────────────────────────────────────────────
# IES Admin Control Panel — environment configuration
# Copy this file to ".env" for local dev, and set the SAME values
# in the Vercel dashboard (Project → Settings → Environment Variables)
# for production. NEVER commit the real .env file (it is git-ignored).
# ─────────────────────────────────────────────────────────────

# The one and only admin login email (IES sets this).
ADMIN_EMAIL=admin@ies-bim.com

# bcrypt hash of the admin password. Generate it with:
#   npm install
#   npm run hash-password "your-strong-password"
# Paste the printed ADMIN_PASSWORD_HASH value here. Never store the
# plain password anywhere.
ADMIN_PASSWORD_HASH=

# Secret used to sign session tokens (JWT). Use a long random string.
# `npm run hash-password` also prints a ready-to-use JWT_SECRET.
JWT_SECRET=

# ── Provisioned automatically by Vercel — do NOT set by hand ──
# When you connect a Redis store (Vercel KV / Upstash) and a Blob store to
# this project, Vercel injects these for you:
#   KV_REST_API_URL
#   KV_REST_API_TOKEN
#   BLOB_READ_WRITE_TOKEN
#
# For LOCAL testing you do NOT need any of the three above: with them unset,
# `npm run dev` saves content to data/content.local.json and images to
# assets/uploads/ automatically. You only need ADMIN_EMAIL, ADMIN_PASSWORD_HASH
# and JWT_SECRET to log in locally.
